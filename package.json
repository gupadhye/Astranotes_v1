{
  "name": "astranotes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AstraNotes — desktop notes app (Electron + Vite)",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --format=cjs --outfile=dist-electron/main.cjs --external:electron --alias:@core=./src/core --alias:@adapters=./src/adapters && esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/preload.cjs --external:electron",
    "dev": "npm run build:electron && concurrently -k \"vite\" \"npm run dev:electron\"",
    "desktop": "npm run dev",
    "dev:electron": "wait-on tcp:5173 && env -u ELECTRON_RUN_AS_NODE VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:web": "vite",
    "build": "npm run build:electron && tsc --noEmit && vite build",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
